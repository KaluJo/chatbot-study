# ============================================================
# CHATBOT STUDY - Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local to version control!
# ============================================================


# ╔════════════════════════════════════════════════════════════╗
# ║                    TIER 1: REQUIRED                        ║
# ║         Without these, the app will not function           ║
# ╚════════════════════════════════════════════════════════════╝

# ------------------------------------------------------------
# SUPABASE (Required - Database & Auth)
# ------------------------------------------------------------
# Get these from: https://supabase.com → Project → Settings → API Keys
#
# Client-side keys (NEXT_PUBLIC) - safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_... # Publishable key (recommended) or anon key

# Server-side key - NEVER expose this publicly
# Get from: Settings → API Keys → Secret key (or service_role in Legacy keys)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_... # Required for server-side operations

# ------------------------------------------------------------
# ANTHROPIC CLAUDE (Required - Chat Responses)
# ------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/
# This powers the core chat functionality with "Day"
# Without this, users cannot have conversations.
#
ANTHROPIC_API_KEY=sk-ant-api03-...
# Latest Claude models (2025):
# - claude-sonnet-4-20250514 (recommended, best balance of quality/speed)
# - claude-3-5-sonnet-20241022 (previous gen, still excellent)
# - claude-3-opus-20240229 (most capable, slower)
# - claude-3-haiku-20240307 (fastest, lower cost)
CLAUDE_MODEL=claude-sonnet-4-5


# ╔════════════════════════════════════════════════════════════╗
# ║                 TIER 2: RECOMMENDED                        ║
# ║     Enhances chat quality with personalized strategies     ║
# ╚════════════════════════════════════════════════════════════╝

# ------------------------------------------------------------
# GOOGLE GEMINI (Recommended - Strategy Generation)
# ------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/apikey
# 
# WHAT IT DOES:
# - Generates personalized conversation strategies based on
#   user's chat history (vertical/horizontal exploration)
# - Extracts topics and contexts from conversations
# - Powers the "thinking" logs for research analysis
#
# WITHOUT IT:
# - Chat still works, but uses generic conversation approach
# - No personalized strategies or memory of past conversations
# - Topic-Context Graph will have limited functionality
#
# Set to empty string to explicitly disable:
# GEMINI_API_KEY=
#
GEMINI_API_KEY=AIzaSy...
# Gemini models (from ai.google.dev/gemini-api/docs/models):
# Stable:
#   - gemini-2.5-flash (best price-performance, recommended)
#   - gemini-2.5-flash-lite (fastest, cost-efficient)
#   - gemini-2.5-pro (advanced thinking)
# Preview:
#   - gemini-3-flash-preview, gemini-3-pro-preview
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro


# ╔════════════════════════════════════════════════════════════╗
# ║                   TIER 3: OPTIONAL                         ║
# ║        Advanced features, graceful fallbacks exist         ║
# ╚════════════════════════════════════════════════════════════╝

# ------------------------------------------------------------
# OPENAI (Optional - Vector Embeddings)
# ------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
#
# WHAT IT DOES:
# - Generates semantic embeddings for topic similarity search
# - Enables smarter topic deduplication in the Value Graph
#
# WITHOUT IT:
# - Falls back to text-based similarity (still works, less accurate)
# - Topic-Context Graph uses keyword matching instead
#
# Set to empty string to explicitly disable:
# OPENAI_API_KEY=
#
OPENAI_API_KEY=sk-proj--


# ╔════════════════════════════════════════════════════════════╗
# ║                  CUSTOMIZATION OPTIONS                     ║
# ║              All have sensible defaults                    ║
# ╚════════════════════════════════════════════════════════════╝

# Chatbot display name (default: Day)
NEXT_PUBLIC_CHATBOT_NAME=Day

# ------------------------------------------------------------
# API KEY MODE (default: false - uses server API keys)
# ------------------------------------------------------------
# Controls whether users must provide their own Gemini API key
# for AI-powered survey features (Stages 2, 3, 4).
#
# TWO MODES:
#
# 1. RESEARCHER MODE (default, false or not set):
#    - Server's GEMINI_API_KEY is used for all users
#    - Users don't need to provide any API keys
#    - You (the researcher) cover all API costs
#    - Best for: Running your own studies with participants
#
# 2. DEMO/PUBLIC MODE (true):
#    - Users must provide their own Gemini API key
#    - Server's GEMINI_API_KEY is NOT used for survey features
#    - Each user pays for their own API usage
#    - Best for: Public demos, workshops, or cost-sharing setups
#
# For most research deployments, leave this commented out or false.
# Only set to true for public demos where you want users to use
# their own API keys.
#
# NEXT_PUBLIC_REQUIRE_USER_API_KEYS=true

#NEXT_PUBLIC_DEMO_MODE=false

# Time between chat sessions in milliseconds (default: 3600000 = 1 hour)
# NEXT_PUBLIC_SESSION_COOLDOWN_MS=3600000

# Minimum session length in minutes (default: 5)
# NEXT_PUBLIC_MIN_SESSION_MINUTES=5


# ============================================================
# QUICK START CHECKLIST
# ============================================================
# 
# Minimum viable setup (chat only):
#   ✓ NEXT_PUBLIC_SUPABASE_URL
#   ✓ NEXT_PUBLIC_SUPABASE_ANON_KEY  
#   ✓ ANTHROPIC_API_KEY
#
# Full research toolkit:
#   ✓ All of the above
#   ✓ GEMINI_API_KEY (for strategies + analysis)
#   ✓ OPENAI_API_KEY (for semantic search)
#
# ============================================================
